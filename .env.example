# Venore V2 - Environment Variables

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite:./venore.db

# ============================================================================
# API SERVER (for venore-api, if used)
# ============================================================================
API_HOST=127.0.0.1
API_PORT=3000

# ============================================================================
# LLM CONFIGURATION
# ============================================================================

# --- API Keys ---
# IMPORTANTE: En producción, las API keys se guardan en OS keychain
# Estas variables son SOLO para desarrollo/testing local
# Obtén tu API key en:
# - Gemini: https://makersuite.google.com/app/apikey (DEFAULT)
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/

GEMINI_API_KEY=your-gemini-key-here
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# --- Task Configuration Overrides (Optional) ---
# Estas variables permiten override de configuración por tarea
# Si no se especifican, se usan los defaults del código

# Onboarding Task (generar .context.md)
# VENORE_TASK_ONBOARDING_PROVIDER=anthropic
# VENORE_TASK_ONBOARDING_MODEL=claude-3-5-sonnet-20241022
# VENORE_TASK_ONBOARDING_TEMPERATURE=0.3
# VENORE_TASK_ONBOARDING_MAX_TOKENS=8000
# VENORE_TASK_ONBOARDING_TIMEOUT_MS=90000
# VENORE_TASK_ONBOARDING_STREAMING=false

# Chat Task (conversación interactiva)
# VENORE_TASK_CHAT_PROVIDER=anthropic
# VENORE_TASK_CHAT_MODEL=claude-3-5-sonnet-20241022
# VENORE_TASK_CHAT_TEMPERATURE=0.7
# VENORE_TASK_CHAT_MAX_TOKENS=4096
# VENORE_TASK_CHAT_TIMEOUT_MS=120000
# VENORE_TASK_CHAT_STREAMING=true

# Analysis Task (análisis de código)
# VENORE_TASK_ANALYSIS_PROVIDER=anthropic
# VENORE_TASK_ANALYSIS_MODEL=claude-3-5-sonnet-20241022
# VENORE_TASK_ANALYSIS_TEMPERATURE=0.2
# VENORE_TASK_ANALYSIS_MAX_TOKENS=8000
# VENORE_TASK_ANALYSIS_TIMEOUT_MS=90000
# VENORE_TASK_ANALYSIS_STREAMING=false

# --- Config Directory (Optional) ---
# Por defecto: ~/.venore
# VENORE_CONFIG_DIR=/custom/path/to/config

# ============================================================================
# LOGGING
# ============================================================================
RUST_LOG=info
# Options: trace, debug, info, warn, error
# Para debug del módulo LLM:
# RUST_LOG=venore_core::llm=debug,info

# ============================================================================
# TESTING
# ============================================================================
# Para ejecutar ejemplos CLI:
# cargo run --example test_llm_basic
# cargo run --example test_llm_advanced
# cargo run --example test_llm_config
