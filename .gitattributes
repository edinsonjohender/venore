# Normalize line endings: store text as LF in the repo regardless of the
# contributor's OS or git autocrlf setting. Kills the "LF will be replaced by
# CRLF" churn and prevents cross-platform diff noise.
* text=auto eol=lf

# Binary files: never treat as text, never diff, never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary

# Lockfiles: text, but mark as generated so GitHub collapses them in diffs.
Cargo.lock      linguist-generated=true
pnpm-lock.yaml  linguist-generated=true
